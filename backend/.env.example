# Copy this to .env and fill in real values. Never commit .env to git.

DJANGO_SECRET_KEY=replace-with-50-char-random-string
DJANGO_SETTINGS_MODULE=config.settings.development

# MySQL
DB_NAME=cbc_guidance
DB_USER=cbc_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=3306

# SendGrid (leave blank in dev — locmem backend is used)
SENDGRID_API_KEY=

# Azure Blob Storage (leave blank in dev — local storage is used)
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_CDN_DOMAIN=

# Production only
ALLOWED_HOST=your-app.azurewebsites.net
FRONTEND_URL=https://your-app.vercel.app
